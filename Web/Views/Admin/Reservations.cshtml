@model IEnumerable<Web.Models.Reservation>
@{
    ViewBag.Title = "All reservations";
    var accNames = ViewBag.AccNames as System.Collections.Generic.Dictionary<int, string>;
}

<div class="wrap" style="padding:40px 0 64px">
    <span class="kicker">Administrator</span>
    <h1 class="serif" style="font-size:40px;margin:6px 0 6px">All reservations</h1>
    <div style="display:flex;gap:8px;margin:6px 0 22px;flex-wrap:wrap">
        <a href="@Url.Action("Users", "Admin")" class="btn btn-ghost" style="padding:7px 14px;font-size:12.5px">Users</a>
        <a href="@Url.Action("Accommodations", "Admin")" class="btn btn-ghost" style="padding:7px 14px;font-size:12.5px">Listings</a>
        <a href="@Url.Action("Reservations", "Admin")" class="btn btn-gold" style="padding:7px 14px;font-size:12.5px">Reservations</a>
        <a href="@Url.Action("Reviews", "Admin")" class="btn btn-ghost" style="padding:7px 14px;font-size:12.5px">Reviews</a>
    </div>

    <div style="border:1px solid var(--border);border-radius:14px;overflow:hidden">
        <table style="width:100%;border-collapse:collapse;font-size:14px">
            <thead>
                <tr style="background:var(--surface);color:var(--text-muted);font-size:12px;text-align:left">
                    <th style="padding:13px 16px">Stay</th>
                    <th style="padding:13px 16px">Guest</th>
                    <th style="padding:13px 16px">Dates</th>
                    <th style="padding:13px 16px">Total</th>
                    <th style="padding:13px 16px">Status</th>
                    <th style="padding:13px 16px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    var canCancel = (r.Status == Web.Models.ReservationStatus.Created || r.Status == Web.Models.ReservationStatus.Approved)
                        && (r.CheckIn - DateTime.Now).TotalHours >= 24;
                    <tr style="border-top:1px solid var(--border-2)">
                        <td style="padding:13px 16px">@(accNames != null && accNames.ContainsKey(r.AccommodationId) ? accNames[r.AccommodationId] : "#" + r.AccommodationId)</td>
                        <td style="padding:13px 16px">@r.GuestUsername</td>
                        <td style="padding:13px 16px">@r.CheckIn.ToString("dd/MM/yyyy") &ndash; @r.CheckOut.ToString("dd/MM/yyyy")</td>
                        <td style="padding:13px 16px">&euro;@r.TotalPrice.ToString("0")</td>
                        <td style="padding:13px 16px"><span class="badge badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                        <td style="padding:13px 16px;text-align:right;white-space:nowrap">
                            @if (r.Status == Web.Models.ReservationStatus.Created)
                            {
                                using (Html.BeginForm("ApproveReservation", "Admin", FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-gold" style="padding:6px 12px;font-size:12px">Approve</button>
                                }
                            }
                            @if (canCancel)
                            {
                                using (Html.BeginForm("CancelReservation", "Admin", FormMethod.Post, new { style = "display:inline;margin-left:6px" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-ghost" style="padding:6px 12px;font-size:12px">Cancel</button>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
