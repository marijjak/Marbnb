@model Web.Models.ViewModels.EditProfileViewModel
@{
    ViewBag.Title = "Edit profile";
}

<div class="wrap" style="padding:40px 0 64px;max-width:640px">
    <a href="@Url.Action("Index", "Profile")" class="muted" style="font-size:13px">&larr; Back to profile</a>
    <h1 class="serif" style="font-size:38px;margin:14px 0 24px">Edit profile</h1>

    <div style="border:1px solid var(--border);border-radius:16px;padding:32px;background:var(--surface-2)">
        @using (Html.BeginForm("Edit", "Profile", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert" })

            <div class="form-row">
                <div class="field">
                    <label>First name</label>
                    @Html.TextBoxFor(m => m.FirstName)
                    @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "val" })
                </div>
                <div class="field">
                    <label>Last name</label>
                    @Html.TextBoxFor(m => m.LastName)
                    @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "val" })
                </div>
            </div>

            <div class="field">
                <label>Email</label>
                @Html.TextBoxFor(m => m.Email, new { type = "email" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "val" })
            </div>

            <div class="form-row">
                <div class="field">
                    <label>Date of birth</label>
                    @Html.TextBoxFor(m => m.DateOfBirth, new { type = "date" })
                    @Html.ValidationMessageFor(m => m.DateOfBirth, "", new { @class = "val" })
                </div>
                <div class="field">
                    <label>Gender</label>
                    @Html.DropDownListFor(m => m.Gender, new SelectList(System.Enum.GetValues(typeof(Web.Models.Gender))))
                    @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "val" })
                </div>
            </div>

            <div class="field">
                <label>New password (leave blank to keep current)</label>
                @Html.PasswordFor(m => m.NewPassword, new { placeholder = "••••••••" })
                @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "val" })
            </div>

            <button type="submit" class="btn btn-gold" style="margin-top:8px">Save changes</button>
        }
    </div>
</div>
