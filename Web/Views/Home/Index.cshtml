@model IEnumerable<Web.Models.Accommodation>
@{
    ViewBag.Title = "Stay beyond ordinary";
    var fType = (string)ViewBag.FType;
    var fSort = (string)ViewBag.FSort;
    Func<string, string> typeSel = v => v == fType ? "selected" : null;
    Func<string, string> sortSel = v => v == fSort ? "selected" : null;
}

<section class="hero">
    <svg class="hero__bg" viewBox="0 0 1180 480" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
            <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#3a3326" />
                <stop offset="0.42" stop-color="#714c2b" />
                <stop offset="0.68" stop-color="#3d2a1c" />
                <stop offset="1" stop-color="#120d09" />
            </linearGradient>
        </defs>
        <rect width="1180" height="480" fill="url(#sky)" />
        <circle cx="880" cy="190" r="60" fill="#d8a85e" opacity="0.38" />
        <circle cx="880" cy="190" r="36" fill="#e8c074" opacity="0.5" />
        <g fill="#0f0a07" opacity="0.92">
            <rect x="40" y="300" width="70" height="180" />
            <rect x="120" y="240" width="52" height="240" />
            <rect x="190" y="330" width="60" height="150" />
            <rect x="520" y="280" width="46" height="200" />
            <rect x="580" y="210" width="62" height="270" />
            <rect x="660" y="310" width="44" height="170" />
            <rect x="980" y="260" width="70" height="220" />
            <rect x="1060" y="320" width="56" height="160" />
            <rect x="760" y="340" width="190" height="140" />
        </g>
    </svg>
    <div class="hero__veil"></div>
    <div class="wrap" style="position:relative">
        <div class="hero__inner">
            <span class="kicker">Exclusive stays</span>
            <h1 class="hero__title">Stay<br />beyond<br /><span class="gold">ordinary</span></h1>
            <p class="hero__sub">Handpicked stays for those who expect a little more from a night away.</p>
            <div class="hero__cta">
                <a href="#featured" class="btn btn-gold">Explore stays &rarr;</a>
                <a href="@Url.Action("Register", "Account")" class="btn btn-ghost">Become a member</a>
            </div>
        </div>
    </div>
</section>

<div class="wrap">
    <div class="searchbar" style="flex-wrap:wrap;max-width:none">
        @using (Html.BeginForm("Index", "Home", FormMethod.Get))
        {
            <div class="search-field" style="flex:1 1 150px">
                <label>Name</label>
                <input type="text" name="name" value="@ViewBag.FName" placeholder="Any name" />
            </div>
            <div class="search-field" style="flex:1 1 130px">
                <label>City</label>
                <input type="text" name="city" value="@ViewBag.FCity" placeholder="Anywhere" />
            </div>
            <div class="search-field" style="flex:1 1 120px">
                <label>Type</label>
                <select name="type">
                    <option value="">Any type</option>
                    <option value="Apartment" @typeSel("Apartment")>Apartment</option>
                    <option value="Hotel" @typeSel("Hotel")>Hotel</option>
                    <option value="Hostel" @typeSel("Hostel")>Hostel</option>
                    <option value="Villa" @typeSel("Villa")>Villa</option>
                    <option value="Cottage" @typeSel("Cottage")>Cottage</option>
                    <option value="Studio" @typeSel("Studio")>Studio</option>
                    <option value="Room" @typeSel("Room")>Room</option>
                </select>
            </div>
            <div class="search-field" style="flex:0 1 90px">
                <label>Min &euro;</label>
                <input type="number" name="minPrice" min="0" value="@ViewBag.FMin" placeholder="0" />
            </div>
            <div class="search-field" style="flex:0 1 90px">
                <label>Max &euro;</label>
                <input type="number" name="maxPrice" min="0" value="@ViewBag.FMax" placeholder="500" />
            </div>
            <div class="search-field" style="flex:1 1 140px">
                <label>Sort by</label>
                <select name="sort">
                    <option value="date_desc" @sortSel("date_desc")>Newest first</option>
                    <option value="date_asc" @sortSel("date_asc")>Oldest first</option>
                    <option value="price_asc" @sortSel("price_asc")>Price: low to high</option>
                    <option value="price_desc" @sortSel("price_desc")>Price: high to low</option>
                    <option value="name_asc" @sortSel("name_asc")>Name: A to Z</option>
                    <option value="name_desc" @sortSel("name_desc")>Name: Z to A</option>
                </select>
            </div>
            <button type="submit" class="btn btn-gold">Search</button>
        }
    </div>
</div>

<section class="section wrap" id="featured">
    <div class="section__head">
        <div>
            <span class="kicker">@(ViewBag.IsFiltered == true ? "Search results" : "Featured properties")</span>
            <h2 class="section__title">@(ViewBag.IsFiltered == true ? Model.Count() + " stays found" : "Discover our finest stays")</h2>
        </div>
        @if (ViewBag.IsFiltered == true)
        {
            <a href="@Url.Action("Index", "Home")" class="muted" style="font-size:13px">Clear filters &times;</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px 0;color:var(--text-muted)">
            <div class="serif" style="font-size:26px;color:var(--text-2);margin-bottom:8px">No stays match your search</div>
            <p>Try widening your filters or <a href="@Url.Action("Index", "Home")" class="gold">clear them</a>.</p>
        </div>
    }
    else
    {
        <div class="grid-stays">
            @foreach (var acc in Model)
            {
                <a class="stay" href="@Url.Action("Details", "Accommodations", new { id = acc.Id })">
                    <div class="stay__img" @(string.IsNullOrEmpty(acc.ImagePath) ? "" : "style=background-image:url(" + Url.Content(acc.ImagePath) + ")")>
                        @if (string.IsNullOrEmpty(acc.ImagePath))
                        {
                            <span style="font-family:'Cormorant Garamond',serif;font-size:64px;color:rgba(201,163,94,.22)">@acc.Name.Substring(0, 1)</span>
                        }
                        <span class="stay__tag">@acc.Type</span>
                        <span class="stay__rate">@(acc.AverageRating > 0 ? "★ " + acc.AverageRating.ToString("0.0") : "New")</span>
                    </div>
                    <div class="stay__body">
                        <div class="stay__loc">@acc.City, Serbia</div>
                        <div class="stay__name">@acc.Name</div>
                        <div class="stay__foot">
                            <span class="stay__meta">Up to @acc.MaxGuests guests</span>
                            <span class="stay__price">&euro;@acc.PricePerNight.ToString("0")<span> /night</span></span>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</section>

<section class="section wrap">
    <div class="section__head">
        <div>
            <span class="kicker">Why marbnb</span>
            <h2 class="section__title">Made for effortless stays</h2>
        </div>
    </div>
    <div class="why">
        <div class="why__item">
            <div class="ic">&#9670;</div>
            <h4>Handpicked stays</h4>
            <p>A selective, quality-first collection across the region.</p>
        </div>
        <div class="why__item">
            <div class="ic">&#9733;</div>
            <h4>Verified hosts</h4>
            <p>Every host is reviewed and approved before listing.</p>
        </div>
        <div class="why__item">
            <div class="ic">&#9889;</div>
            <h4>Instant booking</h4>
            <p>Reserve your stay in just a few calm clicks.</p>
        </div>
        <div class="why__item">
            <div class="ic">&#128274;</div>
            <h4>Secure by design</h4>
            <p>Your data stays private and protected.</p>
        </div>
    </div>
</section>

<section class="section wrap" style="padding-top:0">
    <div class="stats">
        <div><div class="stat__num">@ViewBag.TotalStays</div><div class="stat__lbl">Curated stays</div></div>
        <div><div class="stat__num">@ViewBag.TotalCities</div><div class="stat__lbl">Cities</div></div>
        <div><div class="stat__num">@ViewBag.AvgRating</div><div class="stat__lbl">Average rating</div></div>
        <div><div class="stat__num">@(ViewBag.TotalGuests)+</div><div class="stat__lbl">Happy guests</div></div>
    </div>
</section>
