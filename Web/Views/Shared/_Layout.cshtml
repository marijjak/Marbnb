@{
    var currentUser = Session["username"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - marbnb</title>
    <link rel="icon" href="~/Content/img/favicon.svg" type="image/svg+xml" />
    <link href="~/Content/marbnb.css" rel="stylesheet" />
    @RenderSection("head", required: false)
</head>
<body>
    <header class="wrap">
        <nav class="nav">
            <a href="@Url.Action("Index", "Home")" class="brand">
                <span class="brand__mark">m</span>
                <span>
                    <span class="brand__name">marbnb</span>
                    <span class="brand__tag" style="display:block">THE ART OF STAYING</span>
                </span>
            </a>
            <div class="nav__links">
                <a href="@Url.Action("Index", "Home")">Stays</a>
                <a href="@Url.Action("Index", "Home")#featured">Featured</a>
                @if (currentUser == null)
                {
                    <a href="@Url.Action("Login", "Account")">Log in</a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-gold">Sign up</a>
                }
                else
                {
                    <a href="@Url.Action("Index", "Profile")">@currentUser</a>
                    <a href="@Url.Action("Logout", "Account")" class="btn btn-ghost">Log out</a>
                }
            </div>
        </nav>
    </header>

    @if (TempData["ok"] != null)
    {
        <div class="wrap"><div class="alert alert-ok" style="margin-top:18px">@TempData["ok"]</div></div>
    }
    @if (TempData["err"] != null)
    {
        <div class="wrap"><div class="alert" style="margin-top:18px">@TempData["err"]</div></div>
    }

    @RenderBody()

    <footer class="wrap">
        <div class="footer">
            <span class="serif">marbnb</span>
            <span>Stays &middot; Hosts &middot; About &middot; Contact &middot; &copy; 2026</span>
        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jqueryval")
    @RenderSection("scripts", required: false)
</body>
</html>
